# ==========================================
# LOCAL DEVELOPMENT (CLI & Offline Scripts)
# ==========================================
# Required for YouTube comment scraping
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY_HERE

# Optional: Set this to a different Ollama endpoint if running on a remote host
OLLAMA_API_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=qwen2.5:1.5b

# ==========================================
# CLOUDFLARE PAGES (Frontend)
# ==========================================
# These variables should be set in the Cloudflare Pages dashboard.
# DO NOT put sensitive secrets here!
# Example public environment variables:
# VITE_API_URL=https://rasalytics-api.workers.dev

# ==========================================
# CLOUDFLARE WORKERS (Backend API)
# ==========================================
# For production backend secrets, use `bunx wrangler secret put <NAME>`
# DO NOT commit real secrets to the repository.
# (The edge-safe sentiment API currently does not require secrets).
